# datapull native (no-Docker) production config for a Windows VM.
# Copy to the repo root as `.env`, fill in, and keep it out of source control.

# Run jobs as native Playwright subprocesses (not containers).
DATAPULL_LAUNCHER=native

# Headless browser — REQUIRED when running under NSSM/Windows services (session 0
# has no desktop). Leave unset (or =true) only for the interactive/headed setup.
PARAM_HEADED=false

# Install Playwright's Chromium to a SHARED path (not a per-user profile) so a
# LocalSystem service can find it. Install browsers with this same variable set:
#   set PLAYWRIGHT_BROWSERS_PATH=C:\datapull\ms-playwright
#   .\.venv\Scripts\python.exe -m playwright install chromium
PLAYWRIGHT_BROWSERS_PATH=C:\datapull\ms-playwright

# --- External SQL Server (ODBC Driver 18 must be installed on the VM) ---
# Create the `datapull` database on that instance first.
DATABASE_URL=mssql+pyodbc://USER:PASSWORD@SQLHOST:1433/datapull?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# --- Memurai (Windows-native Redis) on localhost ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# The job subprocess calls the web API running on this same box.
DATAPULL_API_BASE=http://localhost:5000/api

# Where downloads, run logs, and the .runtime PID/console files are written.
OUTPUTS_DIR=C:\datapull\outputs

# --- Secrets (generate fresh; BACK UP SECRET_ENCRYPTION_KEY) ---
#   SECRET_KEY:            python -c "import secrets; print(secrets.token_urlsafe(48))"
#   SECRET_ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
SECRET_ENCRYPTION_KEY=

# --- Bootstrap operator login (used by `flask bootstrap-admin`) ---
ADMIN_EMAIL=admin@datapull.local
ADMIN_PASSWORD=ChangeMe_Admin123
